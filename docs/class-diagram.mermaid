classDiagram
    direction LR

    class Player {
        +string id
        +string name
        +number seatNumber
        +RoleType role
        +boolean isAI
        +boolean isAlive
        +boolean isSheriff
        +string avatarUrl
        +string lastGuardTargetId
        +boolean antidoteUsed
        +boolean poisonUsed
        +boolean isSpectator
    }

    class ChatMessage {
        +string id
        +string playerId
        +string playerName
        +string content
        +string time
        +boolean isAI
    }

    class RoleType {
        <<enumeration>>
        wolf
        civilian
        prophet
        guard
        hunter
        witch
        idiot
        unknown
    }

    class PlayerSeat {
        <<Vue Component>>
        +Player player
        +boolean isSpeaking
        +boolean isSelf
        +number seatIndex
        +number totalSeats
    }

    class CircleTable {
        <<Vue Component>>
        +Player[] players
        +string currentSpeakerId
        +string myId
        +calculateSeatPositions() SeatPosition[]
    }

    class ChatBubble {
        <<Vue Component>>
        +ChatMessage message
        +string myId
        +Player player
    }

    class ChatBox {
        <<Vue Component>>
        +ChatMessage[] messages
        +boolean disabled
        +string myId
        +Player[] players
        +submit(content) void
    }

    class RoleIcon {
        <<Vue Component>>
        +RoleType role
        +number size
    }

    class RoleCard {
        <<Vue Component>>
        +RoleType role
    }

    class GamePlay {
        <<Vue View>>
        +GameState store
        +boolean isNight
        +applyTheme() void
    }

    class AvatarUtil {
        <<Utility>>
        +getPlayerAvatar(Player) string
        +getDefaultAvatar(boolean) string
    }

    Player --> RoleType : role
    PlayerSeat --> Player : player
    CircleTable --> PlayerSeat : contains N
    ChatBox --> ChatBubble : contains N
    ChatBubble --> Player : player
    ChatBubble --> AvatarUtil : uses
    PlayerSeat --> AvatarUtil : uses
    RoleCard --> RoleIcon : uses
    GamePlay --> CircleTable : contains
    GamePlay --> ChatBox : contains
    GamePlay --> RoleCard : contains
